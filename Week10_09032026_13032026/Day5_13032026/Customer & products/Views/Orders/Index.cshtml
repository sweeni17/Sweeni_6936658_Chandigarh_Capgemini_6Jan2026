@model IEnumerable<Order>

<h2>Orders</h2>

@if (Model != null && Model.Any())
{
    <table border="1">

        <tr>
            <th>Customer</th>
            <th>Product</th>
        </tr>

        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Customer.Name</td>
                <td>@order.Product.Name</td>
            </tr>
        }

    </table>
}
else
{
    <p>No orders found</p>
}