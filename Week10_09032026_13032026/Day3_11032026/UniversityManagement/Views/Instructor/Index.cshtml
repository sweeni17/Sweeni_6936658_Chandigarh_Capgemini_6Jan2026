@model IEnumerable<UniversityManagement.Models.Instructor>

<h2>Instructors</h2>

<p>
    <a asp-action="Create">Add Instructor</a>
</p>

<table border="1">
    <tr>
        <th>Name</th>
        <th>Department</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Department</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.InstructorId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.InstructorId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.InstructorId">Delete</a>
            </td>
        </tr>
    }
</table>