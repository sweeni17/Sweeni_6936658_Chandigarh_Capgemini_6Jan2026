@model EcommerceApp.Models.Order

@{
  ViewData["Title"] = "Order Summary";
}

<h1>Order #@Model.OrderId</h1>

<h4>Customer</h4>
<dl class="row">
  <dt class="col-sm-2">Name</dt>
  <dd class="col-sm-10">@Model.Customer?.FullName</dd>
  <dt class="col-sm-2">Email</dt>
  <dd class="col-sm-10">@Model.Customer?.Email</dd>
  <dt class="col-sm-2">Address</dt>
  <dd class="col-sm-10">@Model.Customer?.Address</dd>
</dl>

<h4>Order Details</h4>
<table class="table">
  <thead>
    <tr>
      <th>Product</th>
      <th>Unit Price</th>
      <th>Quantity</th>
      <th>Line Total</th>
    </tr>
  </thead>
  <tbody>
    @if (Model.OrderDetails != null)
    {
      foreach (var d in Model.OrderDetails)
      {
        <tr>
          <td>@d.Product?.Name</td>
          <td>@d.UnitPrice.ToString("C")</td>
          <td>@d.Quantity</td>
          <td>@(d.UnitPrice* d.Quantity).ToString("C")</td>
        </tr>
      }
    }
  </tbody>
  <tfoot>
    <tr>
      <td colspan="3" class="text-end"><strong>Total</strong></td>
      <td>@Model.TotalAmount.ToString("C")</td>
    </tr>
  </tfoot>
</table>

<div>
  <a asp-action="Index" class="btn btn-secondary">Back to List</a>
  <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">Home</a>
</div>