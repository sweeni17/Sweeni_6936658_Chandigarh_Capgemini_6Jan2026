@model IEnumerable<EcommerceApp.Models.Product>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Here are some of our products:</p>
</div>

@if (Model != null && Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(m => m.First().Name)</th>
                <th>@Html.DisplayNameFor(m => m.First().Price)</th>
                <th>@Html.DisplayNameFor(m => m.First().StockQuantity)</th>
                <th>@Html.DisplayNameFor(m => m.First().Category.Name)</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.StockQuantity</td>
                <td>@item.Category?.Name</td>
            </tr>
}
        </tbody>
    </table>
}
else
{
    <p>No products are available at this time.</p>
}
