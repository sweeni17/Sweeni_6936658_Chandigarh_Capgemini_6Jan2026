@model IEnumerable<EcommerceApp.Models.Customer>

@{
  ViewData["Title"] = "Customers";
}

<h1>Customers</h1>

<p>
  <a asp-action="Create" class="btn btn-success">Create New</a>
  <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">Home</a>
</p>
<table class="table table-striped">
  <thead>
    <tr>
      <th>@Html.DisplayNameFor(model => model.FullName)</th>
      <th>@Html.DisplayNameFor(model => model.Email)</th>
      <th>@Html.DisplayNameFor(model => model.Address)</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    @foreach (var item in Model)
    {
      <tr>
        <td>@Html.DisplayFor(modelItem => item.FullName)</td>
        <td>@Html.DisplayFor(modelItem => item.Email)</td>
        <td>@Html.DisplayFor(modelItem => item.Address)</td>
        <td>
          <a asp-action="Edit" asp-route-id="@item.CustomerId" class="btn btn-sm btn-primary">Edit</a>
          <a asp-action="Details" asp-route-id="@item.CustomerId" class="btn btn-sm btn-info ms-1">Details</a>
          <a asp-action="Delete" asp-route-id="@item.CustomerId" class="btn btn-sm btn-danger ms-1">Delete</a>
        </td>
      </tr>
    }
  </tbody>
</table>