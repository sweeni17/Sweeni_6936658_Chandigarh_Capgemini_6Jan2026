@model IEnumerable<Employee_Project_Management_System.Models.Employee>

<div class="container mt-4">

    <h2 class="mb-4">Employees</h2>

    <a class="btn btn-primary mb-3" href="/Employees/Create">Add Employee</a>

    <table class="table table-striped table-hover shadow-sm">

        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Department</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.Name</td>
                    <td>@emp.Department?.Name</td>
                </tr>
            }

        </tbody>

    </table>

</div>