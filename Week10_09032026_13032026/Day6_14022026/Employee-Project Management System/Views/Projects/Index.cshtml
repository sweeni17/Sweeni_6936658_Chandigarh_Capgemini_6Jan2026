@model IEnumerable<Employee_Project_Management_System.Models.Project>

<div class="container mt-4">

    <h2 class="mb-4">Projects</h2>

    <a class="btn btn-primary mb-3" href="/Projects/Create">Add Project</a>

    <table class="table table-striped table-hover shadow-sm">

        <thead class="table-dark">
            <tr>
                <th>Project Title</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var project in Model)
            {
                <tr>
                    <td>@project.Title</td>
                </tr>
            }

        </tbody>

    </table>

    <a class="btn btn-outline-dark mt-3" href="/Projects/Dashboard">View Dashboard</a>

</div>