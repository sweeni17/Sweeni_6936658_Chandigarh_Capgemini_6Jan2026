@model AuthPortal.Models.StudentIndexViewModel

@{
    ViewData["Title"] = "Student Portal - Public";
}

<h1>Student Portal <span class="badge bg-success">Public</span></h1>
<p class="text-muted">This page is accessible without login — read only.</p>
<hr />

<h2>Students</h2>
<table class="table table-bordered table-hover">
    <thead class="table-primary">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Course</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model.Students)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.Email</td>
                <td>@student.Course</td>
            </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <a href="/Admin/Index" class="btn btn-danger">
        Go to Admin Panel (Protected)
    </a>
</div>