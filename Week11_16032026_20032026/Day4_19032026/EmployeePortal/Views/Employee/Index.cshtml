@model IEnumerable<EmployeePortal.Models.Employee>

<div class="container mt-4">

    <h2 class="mb-3">Employee List</h2>

    <!-- 🔍 SEARCH -->
    <form method="get" class="mb-3">
        <input type="text" name="search" class="form-control" placeholder="Search by Name or Department..." />
    </form>

    <!-- ➕ ADD BUTTON (Admin only) -->
    @if (User.IsInRole("Admin"))
    {
        <a class="btn btn-success mb-3" asp-action="Create">Add Employee</a>
    }

    <!-- 📋 TABLE -->
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Department</th>
                <th>Salary</th>
                @if (User.IsInRole("Admin"))
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Department</td>
                    <td>@item.Salary</td>

                    @if (User.IsInRole("Admin"))
                    {
                        <td>
                            <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>