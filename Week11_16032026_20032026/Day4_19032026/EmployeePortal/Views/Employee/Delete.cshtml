@model EmployeePortal.Models.Employee

<div class="container mt-4">
    <div class="card shadow p-4">
        <h3 class="text-danger">Delete Employee</h3>

        <p>Are you sure you want to delete this employee?</p>

        <ul class="list-group mb-3">
            <li class="list-group-item"><strong>Name:</strong> @Model.Name</li>
            <li class="list-group-item"><strong>Department:</strong> @Model.Department</li>
            <li class="list-group-item"><strong>Salary:</strong> @Model.Salary</li>
        </ul>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <button class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>